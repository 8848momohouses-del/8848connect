<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_api_client_form" model="ir.ui.view">
        <field name="name">8848.api.client.form</field>
        <field name="model">8848.api.client</field>
        <field name="arch" type="xml">
            <form string="API Client">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Gravity Forms"/></h1>
                    </div>
                    <group>
                        <group string="Authentication">
                            <field name="key_id"/>
                            <field name="secret_reference"/>
                            <field name="previous_secret_reference"/>
                            <field name="rotation_date"/>
                        </group>
                        <group string="Configuration">
                            <field name="active" widget="boolean_toggle"/>
                            <field name="environment"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="allowed_route_codes"/>
                        </group>
                        <group string="Security Limits">
                            <field name="timestamp_tolerance"/>
                            <field name="rate_limit"/>
                            <field name="allowed_ip_ranges"/>
                        </group>
                        <group string="Tracking">
                            <field name="last_used_at"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Internal notes regarding this API client..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_api_client_list" model="ir.ui.view">
        <field name="name">8848.api.client.list</field>
        <field name="model">8848.api.client</field>
        <field name="arch" type="xml">
            <list string="API Clients">
                <field name="name"/>
                <field name="key_id"/>
                <field name="environment"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="last_used_at"/>
            </list>
        </field>
    </record>

    <record id="action_api_client" model="ir.actions.act_window">
        <field name="name">API Clients</field>
        <field name="res_model">8848.api.client</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
