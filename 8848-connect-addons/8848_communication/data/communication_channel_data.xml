<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Seeded delivery channels. Runtime code looks channels up by
             code (e.g. warehouse packing and delivery-route notifications
             search code='portal'); without these records every notification
             silently no-ops. -->
        <record id="channel_email" model="8848.communication.channel">
            <field name="name">Email</field>
            <field name="code">email</field>
            <field name="sequence">10</field>
        </record>
        <record id="channel_sms" model="8848.communication.channel">
            <field name="name">SMS</field>
            <field name="code">sms</field>
            <field name="sequence">20</field>
        </record>
        <record id="channel_portal" model="8848.communication.channel">
            <field name="name">Portal Notification</field>
            <field name="code">portal</field>
            <field name="sequence">30</field>
        </record>
        <record id="channel_internal" model="8848.communication.channel">
            <field name="name">Internal Note</field>
            <field name="code">internal</field>
            <field name="sequence">40</field>
        </record>
    </data>
</odoo>
