<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_communication_channel_form" model="ir.ui.view">
            <field name="name">8848.communication.channel.form</field>
            <field name="model">8848.communication.channel</field>
            <field name="arch" type="xml">
                <form string="Communication Channel">
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="is_active"/>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="is_active" invisible="1"/>
                            </group>
                            <group>
                                <field name="sequence"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Provider Configuration">
                                <field name="provider_config" widget="code" options="{'mode': 'json'}"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_communication_channel_list" model="ir.ui.view">
            <field name="name">8848.communication.channel.list</field>
            <field name="model">8848.communication.channel</field>
            <field name="arch" type="xml">
                <list string="Communication Channels">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="is_active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="action_communication_channel" model="ir.actions.act_window">
            <field name="name">Channels</field>
            <field name="res_model">8848.communication.channel</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Define communication channels (Email, SMS, Portal).
              </p>
            </field>
        </record>

        <menuitem id="menu_communication_channels"
                  name="Channels"
                  parent="menu_communication_config"
                  action="action_communication_channel"
                  sequence="10"/>
    </data>
</odoo>
