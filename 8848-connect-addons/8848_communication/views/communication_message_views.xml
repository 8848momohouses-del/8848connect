<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_communication_message_form" model="ir.ui.view">
            <field name="name">8848.communication.message.form</field>
            <field name="model">8848.communication.message</field>
            <field name="arch" type="xml">
                <form string="Communication Message" create="false" edit="false">
                    <header>
                        <field name="status" widget="statusbar" statusbar_visible="draft,queued,sent,failed"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Routing">
                                <field name="channel_id"/>
                                <field name="partner_id"/>
                                <field name="res_model"/>
                                <field name="res_id"/>
                            </group>
                            <group string="Dispatch Info">
                                <field name="scheduled_date"/>
                                <field name="template_id"/>
                                <field name="retry_count"/>
                                <field name="mail_message_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Content">
                                <group>
                                    <field name="subject"/>
                                </group>
                                <separator string="Body"/>
                                <field name="body" widget="html" readonly="1"/>
                            </page>
                            <page string="Error Log" invisible="not error_log">
                                <field name="error_log"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_communication_message_list" model="ir.ui.view">
            <field name="name">8848.communication.message.list</field>
            <field name="model">8848.communication.message</field>
            <field name="arch" type="xml">
                <list string="Message Queue" create="false" edit="false" decoration-info="status == 'queued'" decoration-success="status == 'sent'" decoration-danger="status == 'failed'">
                    <field name="scheduled_date"/>
                    <field name="channel_id"/>
                    <field name="partner_id"/>
                    <field name="subject"/>
                    <field name="status" widget="badge" 
                           decoration-info="status == 'queued'" 
                           decoration-success="status == 'sent'" 
                           decoration-danger="status == 'failed'"/>
                    <field name="retry_count"/>
                </list>
            </field>
        </record>
        
        <record id="view_communication_message_search" model="ir.ui.view">
            <field name="name">8848.communication.message.search</field>
            <field name="model">8848.communication.message</field>
            <field name="arch" type="xml">
                <search>
                    <field name="subject"/>
                    <field name="partner_id"/>
                    <field name="res_model"/>
                    <filter string="Queued" name="queued" domain="[('status', '=', 'queued')]"/>
                    <filter string="Failed" name="failed" domain="[('status', '=', 'failed')]"/>
                    <filter string="Sent" name="sent" domain="[('status', '=', 'sent')]"/>
                    
                        <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                        <filter string="Channel" name="group_channel" context="{'group_by': 'channel_id'}"/>
                    
                </search>
            </field>
        </record>

        <record id="action_communication_message" model="ir.actions.act_window">
            <field name="name">Message Queue</field>
            <field name="res_model">8848.communication.message</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_communication_message_search"/>
            <field name="context">{'search_default_queued': 1}</field>
        </record>

        <menuitem id="menu_communication_messages"
                  name="Message Queue"
                  parent="menu_communication_queue"
                  action="action_communication_message"
                  sequence="10"/>
    </data>
</odoo>
