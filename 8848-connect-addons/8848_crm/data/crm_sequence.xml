<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Franchise Enquiries -->
        <record id="seq_franchise_enquiry" model="ir.sequence">
            <field name="name">Franchise Enquiry Sequence</field>
            <field name="code">8848.franchise.enquiry</field>
            <field name="prefix">FRQ-%(year)s-</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>
        
        <!-- Sequence for Franchise Applications -->
        <record id="seq_franchise_application" model="ir.sequence">
            <field name="name">Franchise Application Sequence</field>
            <field name="code">8848.franchise.application</field>
            <field name="prefix">APP-%(year)s-</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
