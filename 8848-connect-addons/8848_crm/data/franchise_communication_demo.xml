<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Channels are owned and seeded by 8848_communication
             (channel_email / channel_internal); re-seeding them here
             collided with the unique code constraint. -->

        <!-- Demo Template -->
        <record id="demo_template_welcome_franchise" model="8848.communication.template">
            <field name="name">Welcome Franchise</field>
            <field name="code">WELCOME-FRANCHISE</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="subject">Welcome to 8848 Momo House, {{ object.name }}!</field>
            <field name="body_html"><![CDATA[
                <p>Hello {{ object.name }},</p>
                <p>Congratulations! Your franchise application for territory <strong>{{ object.territory }}</strong> has been approved.</p>
                <p>We are thrilled to welcome you to the 8848 Momo House family.</p>
            ]]></field>
            <field name="body_text">Welcome to 8848 Momo House, {{ object.name }}! Your franchise application is approved.</field>
            <field name="channel_ids" eval="[(6, 0, [ref('8848_communication.channel_email'), ref('8848_communication.channel_internal')])]"/>
        </record>
    </data>
</odoo>
