<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- We use the existing 8848_security groups and assign CRM roles -->
        
        <!-- Operations/Franchise users can manage leads -->
        <record id="crm_rule_franchise_user" model="ir.rule">
            <field name="name">Franchise User: Read/Write Own or Unassigned Leads</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('8848_security.group_8848_ops_user'))]"/>
        </record>

        <!-- Franchise Managers can manage all leads -->
        <record id="crm_rule_franchise_manager" model="ir.rule">
            <field name="name">Franchise Manager: Manage All Leads</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('8848_security.group_8848_management'))]"/>
        </record>
    </data>
</odoo>
