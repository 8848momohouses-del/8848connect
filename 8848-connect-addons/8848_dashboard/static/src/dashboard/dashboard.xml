<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="8848_dashboard.Dashboard">
    <div class="o_8848_dashboard">
        <div class="o_8848_dash_header">
            <div>
                <h1><t t-esc="greeting"/>, <t t-esc="userName"/></h1>
                <p t-esc="today"/>
            </div>
            <div class="o_8848_dash_brand">8848 <span>Connect</span></div>
        </div>

        <div class="o_8848_dash_grid">
            <t t-foreach="cards" t-as="card" t-key="card.id">
                <div t-att-class="'o_8848_dash_card ' + card.className"
                     role="button"
                     t-on-click="() => this.openApp(card)">
                    <div class="o_8848_dash_card_top">
                        <span class="o_8848_dash_icon">
                            <i t-att-class="'fa fa-fw ' + card.icon" role="img" t-att-aria-label="card.name"/>
                        </span>
                        <span class="o_8848_dash_name" t-esc="card.name"/>
                        <i class="fa fa-arrow-right o_8848_dash_go"/>
                    </div>
                    <div class="o_8848_dash_kpis">
                        <t t-foreach="card.kpis" t-as="kpi" t-key="kpi_index">
                            <div class="o_8848_dash_kpi">
                                <span class="o_8848_dash_num" t-esc="kpiValue(card, kpi_index)"/>
                                <span class="o_8848_dash_lbl" t-esc="kpi.label"/>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </div>
    </div>
</t>

</templates>
