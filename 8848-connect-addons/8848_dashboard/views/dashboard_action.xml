<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- OWL client action rendering the 8848 landing dashboard -->
    <record id="action_8848_dashboard" model="ir.actions.client">
        <field name="name">Dashboard</field>
        <field name="tag">8848_dashboard.dashboard</field>
    </record>

    <!-- Repoint the existing sequence-0 Dashboard menu (owned by
         8848_core_branding) from the board action to this dashboard -->
    <record id="8848_core_branding.menu_8848_dashboard_root" model="ir.ui.menu">
        <field name="action" eval="'ir.actions.client,%d' % ref('8848_dashboard.action_8848_dashboard')"/>
    </record>
</odoo>
