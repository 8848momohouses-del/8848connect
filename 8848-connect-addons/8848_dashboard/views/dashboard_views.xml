<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Custom Board View (defined first: the action references it) -->
        <record id="view_8848_factory_board" model="ir.ui.view">
            <field name="name">8848.factory.board</field>
            <field name="model">board.board</field>
            <field name="arch" type="xml">
                <form string="Factory Dashboard">
                    <board style="2-1">
                        <column>
                            <action name="%(8848_store_performance.action_store_performance)d" string="Top Performing Stores"/>
                        </column>
                        <column>
                            <action name="%(8848_royalty.action_royalty_statement)d" string="Recent Royalty Statements"/>
                        </column>
                    </board>
                </form>
            </field>
        </record>

        <!-- Factory Dashboard action (mirrors board.open_board_my_dash_action:
             view_id points at the board form view itself; v19 board module
             has no separate search view).
             ID intentionally differs from the retired glass client action
             (action_8848_dashboard) to avoid an external-ID model clash. -->
        <record id="action_8848_factory_dashboard" model="ir.actions.act_window">
            <field name="name">Factory Dashboard</field>
            <field name="res_model">board.board</field>
            <field name="view_mode">form</field>
            <field name="context">{'disable_toolbar': True}</field>
            <field name="usage">menu</field>
            <field name="view_id" ref="view_8848_factory_board"/>
        </record>

        <!-- Reuse the existing sequence-0 "Dashboard" root menu (owned by
             8848_core_branding) instead of adding a second dashboards root:
             point it at the Factory Dashboard so it is the landing app. -->
        <record id="8848_core_branding.menu_8848_dashboard_root" model="ir.ui.menu">
            <field name="action" eval="'ir.actions.act_window,%d' % ref('8848_dashboard.action_8848_factory_dashboard')"/>
        </record>

        <!-- Child entry for discoverability inside the Dashboard app -->
        <menuitem id="menu_8848_dashboard"
                  name="Factory Dashboard"
                  parent="8848_core_branding.menu_8848_dashboard_root"
                  action="action_8848_factory_dashboard"
                  sequence="10"/>

    </data>
</odoo>
