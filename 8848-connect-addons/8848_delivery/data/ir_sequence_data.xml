<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Delivery Route -->
        <record id="seq_delivery_route" model="ir.sequence">
            <field name="name">Delivery Route Sequence</field>
            <field name="code">8848.delivery.route</field>
            <field name="prefix">RTE/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
