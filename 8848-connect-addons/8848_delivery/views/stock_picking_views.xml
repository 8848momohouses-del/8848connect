<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_picking_form_inherit_delivery" model="ir.ui.view">
            <field name="name">stock.picking.form.inherit.delivery</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Proof of Delivery" invisible="picking_type_code != 'outgoing'">
                        <group>
                            <group>
                                <field name="route_id"/>
                                <field name="gps_coordinates"/>
                            </group>
                            <group>
                                <field name="proof_of_delivery_image" widget="image" options="{'size': [200, 200]}"/>
                                <field name="customer_signature" widget="signature"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
