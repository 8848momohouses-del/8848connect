<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Driver Group -->
        <record id="group_8848_driver" model="res.groups">
            <field name="name">8848 Connect Driver</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        
        <!-- Record Rule for Delivery Route: Drivers see their own routes -->
        <record id="rule_driver_delivery_route" model="ir.rule">
            <field name="name">Driver: Own Delivery Routes</field>
            <field name="model_id" ref="8848_delivery.model_8848_delivery_route"/>
            <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_8848_driver'))]"/>
        </record>
        
        <!-- Record Rule for Deliveries (stock.picking): Drivers see pickings in their route -->
        <record id="rule_driver_stock_picking" model="ir.rule">
            <field name="name">Driver: Route Pickings</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="domain_force">[('route_id.driver_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_8848_driver'))]"/>
        </record>
    </data>
</odoo>
