<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_employee_form_inherit_driver" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.driver</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <!-- v19: coach_id was removed from the employee form; anchor on Manager -->
                <xpath expr="//field[@name='parent_id']" position="after">
                    <field name="is_driver"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
