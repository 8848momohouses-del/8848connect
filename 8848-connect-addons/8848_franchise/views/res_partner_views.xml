<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View Extension -->
        <record id="view_partner_form_franchise" model="ir.ui.view">
            <field name="name">res.partner.form.franchise</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <!-- Lifecycle stage bar on top of the record -->
                <xpath expr="//sheet" position="before">
                    <header invisible="not is_franchise">
                        <button name="action_start_franchise_approval" type="object" string="Start Approval Process" class="oe_highlight" invisible="franchise_approved"/>
                        <button name="action_send_welcome_message" type="object" string="Send Welcome Message" class="btn-secondary" invisible="not franchise_approved"/>
                        <field name="franchise_stage_id" widget="statusbar"
                               options="{'clickable': '1', 'fold_field': 'fold'}"/>
                    </header>
                </xpath>

                <xpath expr="//div[@name='button_box']" position="inside">
                    <button class="oe_stat_button" type="object" name="action_view_workflows" icon="fa-tasks" invisible="not is_franchise">
                        <field name="workflow_count" widget="statinfo" string="Workflows"/>
                    </button>
                </xpath>

                <!-- Add Checkbox to partner type -->
                <xpath expr="//field[@name='vat']" position="after">
                    <field name="is_franchise"/>
                </xpath>

                <!-- Add Franchise Notebook Page -->
                <xpath expr="//notebook" position="inside">
                    <page string="Franchise Information" invisible="not is_franchise">
                        <group>
                            <group string="Store Details">
                                <field name="store_id"/>
                                <field name="territory"/>
                                <field name="franchise_status"/>
                            </group>
                            <group string="Financial Agreements">
                                <field name="royalty_percentage"/>
                                <field name="marketing_fee_percentage"/>
                            </group>
                            <group string="Lifecycle">
                                <field name="franchise_approved"/>
                                <field name="is_operational"/>
                                <field name="enquiry_date"/>
                                <field name="application_date"/>
                            </group>
                            <group string="Milestones">
                                <field name="agreement_signed_date"/>
                                <field name="deposit_received_date"/>
                                <field name="training_completed_date"/>
                                <field name="grand_opening_date"/>
                                <field name="renewal_date"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- Kanban pipeline: franchisees grouped by lifecycle stage -->
        <record id="view_franchise_kanban" model="ir.ui.view">
            <field name="name">res.partner.kanban.franchise</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <kanban default_group_by="franchise_stage_id" class="o_kanban_small_column">
                    <field name="franchise_stage_id"/>
                    <templates>
                        <t t-name="card">
                            <div class="p-2">
                                <div class="fw-bolder"><field name="name"/></div>
                                <div t-if="record.store_id.raw_value" class="text-muted">
                                    Store: <field name="store_id"/>
                                </div>
                                <div t-if="record.territory.raw_value" class="text-muted">
                                    <field name="territory"/>
                                </div>
                                <div class="mt-1">
                                    <field name="franchise_status" widget="badge"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Search view with lifecycle filters -->
        <record id="view_franchise_search" model="ir.ui.view">
            <field name="name">res.partner.search.franchise</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <search string="Franchisees">
                    <field name="name"/>
                    <field name="store_id"/>
                    <field name="territory"/>
                    <field name="franchise_stage_id"/>
                    <filter string="Operational" name="operational"
                            domain="[('is_operational', '=', True)]"/>
                    <filter string="Approved" name="approved"
                            domain="[('franchise_approved', '=', True)]"/>
                    <separator/>
                    <filter string="Active" name="status_active"
                            domain="[('franchise_status', '=', 'active')]"/>
                    <filter string="Suspended" name="status_suspended"
                            domain="[('franchise_status', '=', 'suspended')]"/>
                    <group colspan="16">
                        <filter string="Lifecycle Stage" name="group_stage"
                                context="{'group_by': 'franchise_stage_id'}"/>
                        <filter string="Territory" name="group_territory"
                                context="{'group_by': 'territory'}"/>
                        <filter string="Status" name="group_status"
                                context="{'group_by': 'franchise_status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Window Action for Franchises -->
        <record id="action_8848_franchise" model="ir.actions.act_window">
            <field name="name">Franchises</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('is_franchise', '=', True)]</field>
            <field name="context">{'default_is_franchise': True}</field>
            <field name="search_view_id" ref="view_franchise_search"/>
        </record>

        <!-- Bind the franchise kanban to the action (list/form stay the shared
             partner views so the franchise page/header extension applies) -->
        <record id="action_8848_franchise_view_kanban" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">kanban</field>
            <field name="view_id" ref="view_franchise_kanban"/>
            <field name="act_window_id" ref="action_8848_franchise"/>
        </record>

        <!-- Lifecycle stage configuration (admin) -->
        <record id="action_8848_franchise_stage" model="ir.actions.act_window">
            <field name="name">Lifecycle Stages</field>
            <field name="res_model">8848.franchise.stage</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu Items -->
        <menuitem id="menu_8848_franchise_root" name="Franchise" sequence="10" web_icon="8848_franchise,static/description/icon.png"/>
        <menuitem id="menu_8848_franchise_list" name="Franchisees" parent="menu_8848_franchise_root" action="action_8848_franchise" sequence="1"/>
        <menuitem id="menu_8848_franchise_config" name="Configuration" parent="menu_8848_franchise_root" sequence="90" groups="base.group_system"/>
        <menuitem id="menu_8848_franchise_stages" name="Lifecycle Stages" parent="menu_8848_franchise_config" action="action_8848_franchise_stage" sequence="1"/>
    </data>
</odoo>
