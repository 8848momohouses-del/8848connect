<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- List View -->
        <record id="view_marketing_fee_statement_tree" model="ir.ui.view">
            <field name="name">8848.marketing.fee.statement.list</field>
            <field name="model">8848.marketing.fee.statement</field>
            <field name="arch" type="xml">
                <list string="Marketing Fee Statements">
                    <field name="name"/>
                    <field name="franchise_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="total_sales"/>
                    <field name="marketing_fee_amount"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'paid'" decoration-warning="state == 'invoiced'"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_marketing_fee_statement_form" model="ir.ui.view">
            <field name="name">8848.marketing.fee.statement.form</field>
            <field name="model">8848.marketing.fee.statement</field>
            <field name="arch" type="xml">
                <form string="Marketing Fee Statement">
                    <header>
                        <button name="action_generate_invoice" string="Generate Invoice" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,invoiced,paid"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="franchise_id" readonly="state != 'draft'"/>
                                <field name="date_start" readonly="state != 'draft'"/>
                                <field name="date_end" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="total_sales" readonly="state != 'draft'"/>
                                <field name="marketing_fee_percentage" widget="percentage"/>
                                <field name="marketing_fee_amount"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="company_id" invisible="1"/>
                                <field name="invoice_id" invisible="not invoice_id"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_marketing_fee_statement" model="ir.actions.act_window">
            <field name="name">Marketing Fee Statements</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">8848.marketing.fee.statement</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menus -->
        <menuitem id="menu_8848_marketing_fee_statement" name="Marketing Fee Statements" parent="8848_royalty.menu_8848_financials_root" action="action_marketing_fee_statement" sequence="2"/>
    </data>
</odoo>
