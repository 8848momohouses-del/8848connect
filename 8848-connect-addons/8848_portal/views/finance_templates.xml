<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Invoices List -->
        <template id="portal_franchise_invoices" name="Invoices">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <h3 class="mb-4">Invoices</h3>
                    <div class="list-group">
                        <t t-foreach="invoices" t-as="inv">
                            <a t-attf-href="/my/invoices/{{inv.id}}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="mb-1"><t t-esc="inv.name"/></h5>
                                    <small class="text-muted"><t t-esc="inv.invoice_date" t-options="{'widget': 'date'}"/></small>
                                </div>
                                <div>
                                    <span t-attf-class="badge #{'bg-success' if inv.payment_state == 'paid' else 'bg-warning'} me-2">
                                        <t t-esc="inv.payment_state"/>
                                    </span>
                                    <span class="fw-bold">$<t t-esc="'%.2f' % inv.amount_total"/></span>
                                </div>
                            </a>
                        </t>
                        <t t-if="not invoices">
                            <div class="alert alert-info">You have no invoices.</div>
                        </t>
                    </div>
                </div>
            </t>
        </template>
        
        <!-- Invoice Details -->
        <template id="portal_franchise_invoice_details" name="Invoice Details">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3>Invoice <t t-esc="invoice.name"/></h3>
                        <a href="/my/invoices" class="btn btn-outline-secondary">Back to List</a>
                    </div>
                    <div class="card mb-4">
                        <div class="card-body">
                            <p><strong>Date:</strong> <t t-esc="invoice.invoice_date"/></p>
                            <p><strong>Due Date:</strong> <t t-esc="invoice.invoice_date_due"/></p>
                            <p><strong>Amount Due:</strong> $<t t-esc="'%.2f' % invoice.amount_residual"/></p>
                            <p><strong>Status:</strong> <span class="badge bg-secondary"><t t-esc="invoice.payment_state"/></span></p>
                        </div>
                    </div>
                    
                    <table class="table table-striped mt-3">
                        <thead>
                            <tr>
                                <th>Description</th>
                                <th class="text-end">Quantity</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Taxes</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="invoice.invoice_line_ids" t-as="line">
                                <tr>
                                    <td><t t-esc="line.name"/></td>
                                    <td class="text-end"><t t-esc="line.quantity"/></td>
                                    <td class="text-end">$<t t-esc="'%.2f' % line.price_unit"/></td>
                                    <td class="text-end"><t t-esc="', '.join(line.tax_ids.mapped('name'))"/></td>
                                    <td class="text-end">$<t t-esc="'%.2f' % line.price_subtotal"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </template>

        <!-- Statements List -->
        <template id="portal_franchise_statements" name="Royalty Statements">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <h3 class="mb-4">Royalty Statements</h3>
                    <div class="list-group">
                        <t t-foreach="statements" t-as="stmt">
                            <a t-attf-href="/my/statements/{{stmt.id}}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="mb-1"><t t-esc="stmt.name"/></h5>
                                    <small class="text-muted"><t t-esc="stmt.date_start"/> to <t t-esc="stmt.date_end"/></small>
                                </div>
                                <div>
                                    <span t-attf-class="badge #{'bg-success' if stmt.state == 'invoiced' else 'bg-warning'} me-2">
                                        <t t-esc="stmt.state"/>
                                    </span>
                                    <span class="fw-bold">$<t t-esc="'%.2f' % stmt.royalty_amount"/></span>
                                </div>
                            </a>
                        </t>
                        <t t-if="not statements">
                            <div class="alert alert-info">No statements found.</div>
                        </t>
                    </div>
                </div>
            </t>
        </template>
        
        <!-- Statement Details -->
        <template id="portal_franchise_statement_details" name="Statement Details">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3>Statement <t t-esc="stmt.name"/></h3>
                        <a href="/my/statements" class="btn btn-outline-secondary">Back to List</a>
                    </div>
                    <div class="card mb-4">
                        <div class="card-body">
                            <p><strong>Period:</strong> <t t-esc="stmt.date_start"/> - <t t-esc="stmt.date_end"/></p>
                            <p><strong>Gross Sales:</strong> $<t t-esc="'%.2f' % stmt.gross_sales"/></p>
                            <p><strong>Royalty Amount:</strong> $<t t-esc="'%.2f' % stmt.royalty_amount"/></p>
                            <p t-if="stmt.invoice_id"><strong>Invoice:</strong> <a t-attf-href="/my/invoices/{{stmt.invoice_id.id}}"><t t-esc="stmt.invoice_id.name"/></a></p>
                        </div>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>
