<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Franchise Catalogue Page -->
        <template id="portal_franchise_catalogue" name="Franchise Catalogue">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3>Factory Replenishment</h3>
                        <a href="/my/franchise" class="btn btn-outline-secondary">Back to Dashboard</a>
                    </div>
                    
                    <div class="row">
                        <t t-foreach="products" t-as="product">
                            <div class="col-md-3 mb-4">
                                <div class="card h-100 shadow-sm">
                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title"><t t-esc="product.name"/></h5>
                                        <h6 class="text-muted"><t t-esc="product.default_code"/></h6>
                                        <p class="card-text mt-auto mb-3">
                                            <strong>$<t t-esc="'%.2f' % product_prices[product.id]"/></strong>
                                            <small class="text-muted"> / <t t-esc="product.uom_id.name"/></small>
                                        </p>
                                        <form action="/my/orders/cart/update" method="post">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <input type="hidden" name="product_id" t-att-value="product.id"/>
                                            <div class="input-group">
                                                <input type="number" name="quantity" class="form-control" value="1" min="1"/>
                                                <button type="submit" class="btn btn-primary"><i class="fa fa-shopping-cart"/></button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </t>
                        <t t-if="not products">
                            <div class="col-12">
                                <div class="alert alert-info">No products available in the catalogue right now.</div>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>
