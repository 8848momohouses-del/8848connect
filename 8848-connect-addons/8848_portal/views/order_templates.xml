<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Franchise Catalogue Page -->
        <template id="portal_franchise_catalogue" name="Franchise Catalogue">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <t t-if="draft_order">
                        <div class="alert alert-warning d-flex justify-content-between align-items-center">
                            <div>
                                <strong>You have an active draft order (<t t-esc="draft_order.name"/>).</strong>
                                <span>Total: $<t t-esc="'%.2f' % draft_order.amount_total"/></span>
                            </div>
                            <form action="/my/orders/cart/submit" method="post" class="m-0">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <input type="hidden" name="order_id" t-att-value="draft_order.id"/>
                                <button type="submit" class="btn btn-success btn-sm">Submit for Approval</button>
                            </form>
                        </div>
                    </t>
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3>Factory Replenishment</h3>
                        <a href="/my/franchise" class="btn btn-outline-secondary">Back to Dashboard</a>
                    </div>
                    
                    <div class="row">
                        <t t-foreach="products" t-as="product">
                            <div class="col-md-3 mb-4">
                                <div class="card h-100 shadow-sm">
                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title"><t t-esc="product.name"/></h5>
                                        <h6 class="text-muted"><t t-esc="product.default_code"/></h6>
                                        <p class="card-text mt-auto mb-3">
                                            <strong>$<t t-esc="'%.2f' % product_prices[product.id]"/></strong>
                                            <small class="text-muted"> / <t t-esc="product.uom_id.name"/></small>
                                        </p>
                                        <form action="/my/orders/cart/update" method="post">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <input type="hidden" name="product_id" t-att-value="product.id"/>
                                            <div class="input-group">
                                                <input type="number" name="quantity" class="form-control" value="1" min="1"/>
                                                <button type="submit" class="btn btn-primary"><i class="fa fa-shopping-cart"/></button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </t>
                        <t t-if="not products">
                            <div class="col-12">
                                <div class="alert alert-info">No products available in the catalogue right now.</div>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </template>

        <!-- Order History -->
        <template id="portal_franchise_order_history" name="Order History">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <h3 class="mb-4">Order History</h3>
                    <div class="list-group">
                        <t t-foreach="orders" t-as="order">
                            <a t-attf-href="/my/orders/{{order.id}}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="mb-1"><t t-esc="order.name"/></h5>
                                    <small class="text-muted"><t t-esc="order.date_order" t-options="{'widget': 'date'}"/></small>
                                </div>
                                <div>
                                    <span class="badge bg-primary me-2"><t t-esc="order.approval_state"/></span>
                                    <span class="fw-bold">$<t t-esc="'%.2f' % order.amount_total"/></span>
                                </div>
                            </a>
                        </t>
                        <t t-if="not orders">
                            <div class="alert alert-info">You have no previous orders.</div>
                        </t>
                    </div>
                </div>
            </t>
        </template>
        
        <!-- Order Details -->
        <template id="portal_franchise_order_details" name="Order Details">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3>Order <t t-esc="order.name"/></h3>
                        <form t-attf-action="/my/orders/{{order.id}}/reorder" method="post" class="m-0">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <button type="submit" class="btn btn-primary"><i class="fa fa-refresh me-2"/>Reorder Items</button>
                        </form>
                    </div>
                    
                    <div class="card mb-4">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <strong>Date:</strong> <t t-esc="order.date_order" t-options="{'widget': 'datetime'}"/><br/>
                                    <strong>Status:</strong> <span class="badge bg-secondary"><t t-esc="order.approval_state"/></span>
                                </div>
                                <div class="col-md-6 text-end">
                                    <strong>Total:</strong> $<t t-esc="'%.2f' % order.amount_total"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <h4>Order Lines</h4>
                    <table class="table table-striped mt-3">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Quantity</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="order.order_line" t-as="line">
                                <tr>
                                    <td><t t-esc="line.product_id.name"/></td>
                                    <td class="text-end"><t t-esc="line.product_uom_qty"/> <t t-esc="line.product_uom.name"/></td>
                                    <td class="text-end">$<t t-esc="'%.2f' % line.price_unit"/></td>
                                    <td class="text-end">$<t t-esc="'%.2f' % line.price_subtotal"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </template>
    </data>
</odoo>
