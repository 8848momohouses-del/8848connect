<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Add Link to My Account Home -->
        <template id="portal_my_home_franchise" name="Show Franchise Dashboard" inherit_id="portal.portal_my_home">
            <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
                <t t-if="request.env.user._get_permitted_franchise_ids()">
                    <div class="o_portal_category row g-2 mt-3" id="portal_franchise">
                        <a href="/my/franchise" class="col-12 col-md-4 text-decoration-none">
                            <div class="card h-100 bg-light">
                                <div class="card-body">
                                    <h5 class="card-title text-primary"><i class="fa fa-briefcase me-2"/>Franchise Dashboard</h5>
                                    <p class="card-text text-muted">View your store metrics, deliveries, and royalties.</p>
                                </div>
                            </div>
                        </a>
                    </div>
                </t>
            </xpath>
        </template>

        <!-- Franchise Dashboard Page -->
        <template id="portal_franchise_dashboard" name="Franchise Dashboard">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3>Welcome back, <t t-esc="active_franchise.name"/></h3>
                        
                        <!-- Multi-store Selector -->
                        <t t-if="len(permitted_franchises) &gt; 1">
                            <form action="/my/franchise/select" method="post" class="d-inline-block">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <select name="franchise_id" class="form-select" onchange="this.form.submit()">
                                    <t t-foreach="permitted_franchises" t-as="f">
                                        <option t-att-value="f.id" t-att-selected="f.id == active_franchise.id"><t t-esc="f.name"/></option>
                                    </t>
                                </select>
                            </form>
                        </t>
                    </div>

                    <div class="row g-4 mb-5">
                        <div class="col-md-4">
                            <div class="card h-100 shadow-sm border-0">
                                <div class="card-body text-center">
                                    <h5 class="text-muted mb-3">Pending Deliveries</h5>
                                    <h2 class="text-primary fw-bold"><a href="/my/deliveries" class="text-decoration-none"><t t-esc="len(pending_deliveries)"/></a></h2>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-4">
                            <div class="card h-100 shadow-sm border-0">
                                <div class="card-body text-center">
                                    <h5 class="text-muted mb-3">Outstanding Balance</h5>
                                    <h2 class="text-danger fw-bold"><a href="/my/invoices" class="text-danger text-decoration-none">$<t t-esc="'%.2f' % outstanding_balance"/></a></h2>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card h-100 shadow-sm border-0">
                                <div class="card-body text-center">
                                    <h5 class="text-muted mb-3">Statements</h5>
                                    <h2 class="text-primary fw-bold"><a href="/my/statements" class="text-decoration-none"><t t-esc="len(statements)"/></a></h2>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row mt-4">
                        <div class="col-md-3 mb-3"><a href="/my/orders/new" class="btn btn-outline-primary w-100 py-3"><i class="fa fa-shopping-cart d-block mb-2 fa-2x"/>Order Stock</a></div>
                        <div class="col-md-3 mb-3"><a href="/my/orders" class="btn btn-outline-primary w-100 py-3"><i class="fa fa-history d-block mb-2 fa-2x"/>Order History</a></div>
                        <div class="col-md-3 mb-3"><a href="/my/support" class="btn btn-outline-primary w-100 py-3"><i class="fa fa-life-ring d-block mb-2 fa-2x"/>Support Tickets</a></div>
                        <div class="col-md-3 mb-3"><a href="/my/documents" class="btn btn-outline-primary w-100 py-3"><i class="fa fa-file-text-o d-block mb-2 fa-2x"/>Documents</a></div>
                    </div>
                </div>
            </t>
        </template>
        
        <!-- Portal Menu Navigation -->
        <template id="portal_my_home_menu_franchise" name="Portal Menu Franchise" inherit_id="portal.portal_my_home_menu">
            <xpath expr="//div[@id='o_portal_my_home_menu']" position="inside">
                <t t-if="request.env.user._get_permitted_franchise_ids()">
                    <a href="/my/franchise" class="list-group-item list-group-item-action d-flex align-items-center">
                        <i class="fa fa-briefcase fa-fw me-3"/>Dashboard
                    </a>
                    <a href="/my/orders/new" class="list-group-item list-group-item-action d-flex align-items-center">
                        <i class="fa fa-shopping-cart fa-fw me-3"/>Order Stock
                    </a>
                    <a href="/my/deliveries" class="list-group-item list-group-item-action d-flex align-items-center">
                        <i class="fa fa-truck fa-fw me-3"/>Deliveries
                    </a>
                    <a href="/my/support" class="list-group-item list-group-item-action d-flex align-items-center">
                        <i class="fa fa-life-ring fa-fw me-3"/>Support
                    </a>
                </t>
            </xpath>
        </template>
    </data>
</odoo>
