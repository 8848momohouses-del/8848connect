<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Documents List -->
        <template id="portal_franchise_documents" name="Documents">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <h3 class="mb-4">Franchise Documents</h3>
                    <div class="list-group">
                        <t t-foreach="documents" t-as="doc">
                            <a t-attf-href="/web/content/ir.attachment/{{doc.id}}/datas?download=true" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="fa fa-file-text-o me-2 text-primary"/>
                                    <span class="mb-1"><t t-esc="doc.name"/></span>
                                </div>
                                <span class="badge bg-secondary">Download</span>
                            </a>
                        </t>
                        <t t-if="not documents">
                            <div class="alert alert-info">No documents attached to this franchise.</div>
                        </t>
                    </div>
                </div>
            </t>
        </template>
        
        <!-- Profile View -->
        <template id="portal_franchise_profile" name="My Profile">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <h3 class="mb-4">My Profile</h3>
                    
                    <t t-if="request.params.get('success')">
                        <div class="alert alert-success">Profile update request submitted successfully. Our team will review the changes.</div>
                    </t>
                    
                    <form action="/my/profile/update" method="post" class="card shadow-sm">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="card-body">
                            <div class="mb-3">
                                <label for="name" class="form-label">Full Name</label>
                                <input type="text" class="form-control" name="name" t-att-value="partner.name" required="required"/>
                            </div>
                            <div class="mb-3">
                                <label for="phone" class="form-label">Phone</label>
                                <input type="text" class="form-control" name="phone" t-att-value="partner.phone"/>
                            </div>
                            <div class="mb-3">
                                <label for="email" class="form-label">Email (Login)</label>
                                <input type="email" class="form-control" name="email" t-att-value="partner.email" readonly="1" help="Email cannot be changed directly."/>
                            </div>
                            <button type="submit" class="btn btn-primary">Request Update</button>
                        </div>
                    </form>
                </div>
            </t>
        </template>
    </data>
</odoo>
