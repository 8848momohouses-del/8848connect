<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_portal_access" model="ir.ui.view">
            <field name="name">res.partner.form.portal.access</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="8848_franchise.view_partner_form_8848_franchise"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_invite_portal" type="object" string="Invite Portal User" class="btn-secondary" invisible="not is_franchise"/>
                </xpath>
                <xpath expr="//page[@name='franchise_info']" position="after">
                    <page name="portal_access" string="Portal Access" invisible="not is_franchise">
                        <field name="portal_access_ids">
                            <tree editable="bottom">
                                <field name="user_id"/>
                                <field name="portal_role"/>
                                <field name="state"/>
                                <field name="invited_at" readonly="1"/>
                                <field name="activated_at" readonly="1"/>
                                <button name="action_activate" type="object" string="Activate" invisible="state == 'active'"/>
                                <button name="action_suspend" type="object" string="Suspend" invisible="state != 'active'"/>
                                <button name="action_revoke" type="object" string="Revoke" invisible="state == 'revoked'"/>
                            </tree>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
