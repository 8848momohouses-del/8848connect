<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Messages List -->
        <template id="portal_franchise_messages" name="Announcements &amp; Messages">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <h3 class="mb-4">Announcements &amp; Messages</h3>
                    <div class="list-group">
                        <t t-foreach="messages" t-as="msg">
                            <div class="list-group-item">
                                <h5><t t-esc="msg.subject"/></h5>
                                <p class="mb-1"><t t-raw="msg.body"/></p>
                                <small class="text-muted"><t t-esc="msg.date" t-options="{'widget': 'datetime'}"/></small>
                            </div>
                        </t>
                        <t t-if="not messages">
                            <div class="alert alert-info">No new messages.</div>
                        </t>
                    </div>
                </div>
            </t>
        </template>
        
        <!-- Support List -->
        <template id="portal_franchise_support" name="Support Tickets">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3>Support Tickets</h3>
                        <a href="/my/support/new" class="btn btn-primary">Create New Ticket</a>
                    </div>
                    <div class="list-group">
                        <t t-foreach="tickets" t-as="ticket">
                            <a t-attf-href="/my/support/{{ticket.id}}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="mb-1"><t t-esc="ticket.name"/></h5>
                                    <small class="text-muted"><t t-esc="ticket.create_date" t-options="{'widget': 'date'}"/></small>
                                </div>
                                <div>
                                    <span t-attf-class="badge #{'bg-success' if ticket.state == 'resolved' else 'bg-warning'}"><t t-esc="ticket.state"/></span>
                                </div>
                            </a>
                        </t>
                        <t t-if="not tickets">
                            <div class="alert alert-info">No support tickets found.</div>
                        </t>
                    </div>
                </div>
            </t>
        </template>
        
        <!-- New Support Ticket -->
        <template id="portal_franchise_support_new" name="New Support Ticket">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <h3 class="mb-4">Submit a Support Ticket</h3>
                    <form action="/my/support/create" method="post" class="card shadow-sm">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="card-body">
                            <div class="mb-3">
                                <label for="subject" class="form-label">Subject</label>
                                <input type="text" class="form-control" name="subject" required="required"/>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="category" class="form-label">Category</label>
                                    <select name="category" class="form-select" required="required">
                                        <option value="order">Order Issue</option>
                                        <option value="delivery">Delivery Issue</option>
                                        <option value="quality">Quality Complaint</option>
                                        <option value="finance">Billing &amp; Finance</option>
                                        <option value="other">Other</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label for="priority" class="form-label">Priority</label>
                                    <select name="priority" class="form-select" required="required">
                                        <option value="low">Low</option>
                                        <option value="medium" selected="selected">Medium</option>
                                        <option value="high">High</option>
                                        <option value="urgent">Urgent</option>
                                    </select>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="description" class="form-label">Description</label>
                                <textarea name="description" class="form-control" rows="5" required="required"></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">Submit Ticket</button>
                            <a href="/my/support" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </t>
        </template>
        
        <!-- Support Ticket Details -->
        <template id="portal_franchise_support_details" name="Ticket Details">
            <t t-call="portal.portal_layout">
                <div class="container mt-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3><t t-esc="ticket.name"/></h3>
                        <a href="/my/support" class="btn btn-outline-secondary">Back to List</a>
                    </div>
                    <div class="card mb-4">
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-md-3"><strong>Category:</strong> <t t-esc="ticket.category"/></div>
                                <div class="col-md-3"><strong>Priority:</strong> <t t-esc="ticket.priority"/></div>
                                <div class="col-md-3"><strong>Status:</strong> <span class="badge bg-secondary"><t t-esc="ticket.state"/></span></div>
                                <div class="col-md-3"><strong>Date:</strong> <t t-esc="ticket.create_date" t-options="{'widget': 'datetime'}"/></div>
                            </div>
                            <hr/>
                            <p class="whitespace-pre-wrap"><t t-esc="ticket.description"/></p>
                        </div>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>
