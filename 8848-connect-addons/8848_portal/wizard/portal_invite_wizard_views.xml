<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_portal_invite_wizard_form" model="ir.ui.view">
        <field name="name">8848.portal.invite.wizard.form</field>
        <field name="model">8848.portal.invite.wizard</field>
        <field name="arch" type="xml">
            <form string="Invite Portal User">
                <sheet>
                    <group>
                        <field name="franchise_id" invisible="1"/>
                        <field name="partner_id" options="{'no_create': True}"/>
                        <field name="portal_role"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Send Invite" type="object" name="action_invite" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
