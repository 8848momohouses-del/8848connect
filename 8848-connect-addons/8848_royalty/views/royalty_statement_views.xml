<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_royalty_statement_tree" model="ir.ui.view">
            <field name="name">8848.royalty.statement.tree</field>
            <field name="model">8848.royalty.statement</field>
            <field name="arch" type="xml">
                <tree string="Royalty Statements">
                    <field name="name"/>
                    <field name="franchise_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="total_sales"/>
                    <field name="royalty_amount"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'paid'" decoration-warning="state == 'invoiced'"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_royalty_statement_form" model="ir.ui.view">
            <field name="name">8848.royalty.statement.form</field>
            <field name="model">8848.royalty.statement</field>
            <field name="arch" type="xml">
                <form string="Royalty Statement">
                    <header>
                        <button name="action_generate_invoice" string="Generate Invoice" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,invoiced,paid"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="franchise_id" readonly="state != 'draft'"/>
                                <field name="date_start" readonly="state != 'draft'"/>
                                <field name="date_end" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="total_sales" readonly="state != 'draft'"/>
                                <field name="royalty_percentage" widget="percentage"/>
                                <field name="royalty_amount"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="company_id" invisible="1"/>
                                <field name="invoice_id" invisible="not invoice_id"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_royalty_statement" model="ir.actions.act_window">
            <field name="name">Royalty Statements</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">8848.royalty.statement</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- Menus -->
        <menuitem id="menu_8848_financials_root" name="Financials" sequence="20" parent="8848_franchise.menu_8848_franchise_root"/>
        <menuitem id="menu_8848_royalty_statement" name="Royalty Statements" parent="menu_8848_financials_root" action="action_royalty_statement" sequence="1"/>
    </data>
</odoo>
