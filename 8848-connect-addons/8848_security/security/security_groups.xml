<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 
            8848_SECURITY GROUP HIERARCHY
            =============================
            - Manager groups imply their respective User groups.
            - CEO implies GM.
            - NO GROUP automatically implies IT or System Administration access.
        -->

        <!-- ========================= -->
        <!-- EXECUTIVE                 -->
        <!-- ========================= -->
        <record id="group_8848_gm" model="res.groups">
            <field name="name">General Manager</field>
            <field name="category_id" ref="module_category_8848_connect"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Broad operational management access.</field>
        </record>

        <record id="group_8848_ceo" model="res.groups">
            <field name="name">CEO</field>
            <field name="category_id" ref="module_category_8848_connect"/>
            <field name="implied_ids" eval="[(4, ref('8848_security.group_8848_gm'))]"/>
