<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_store_performance" model="ir.ui.view">
        <field name="name">res.partner.form.store.performance</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_store_performance" type="object"
                        class="oe_stat_button" icon="fa-line-chart"
                        invisible="not is_franchise">
                    <field name="store_performance_count" widget="statinfo"
                           string="Performance"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
