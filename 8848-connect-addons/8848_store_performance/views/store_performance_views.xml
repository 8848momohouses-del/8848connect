<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- List View -->
        <record id="view_store_performance_list" model="ir.ui.view">
            <field name="name">8848.store.performance.list</field>
            <field name="model">8848.store.performance</field>
            <field name="arch" type="xml">
                <list string="Store Performances">
                    <field name="period"/>
                    <field name="franchise_id"/>
                    <field name="monthly_sales"/>
                    <field name="customer_rating" widget="progressbar"/>
                    <field name="compliance_score" widget="progressbar"/>
                    <field name="total_score" widget="progressbar"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_store_performance_form" model="ir.ui.view">
            <field name="name">8848.store.performance.form</field>
            <field name="model">8848.store.performance</field>
            <field name="arch" type="xml">
                <form string="Store Performance">
                    <sheet>
                        <group>
                            <group>
                                <field name="franchise_id"/>
                                <field name="period"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="monthly_sales"/>
                                <field name="customer_rating"/>
                                <field name="compliance_score"/>
                                <field name="total_score"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_store_performance" model="ir.actions.act_window">
            <field name="name">Store Performance</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">8848.store.performance</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu -->
        <menuitem id="menu_store_performance" name="Store Performance" parent="8848_franchise.menu_8848_franchise_root" action="action_store_performance" sequence="20"/>
    </data>
</odoo>
