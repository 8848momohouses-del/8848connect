<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_production_lot_form_inherit_8848_warehouse" model="ir.ui.view">
        <field name="name">stock.lot.form.inherit.8848.warehouse</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_pass_qa" string="Pass QA" type="object" class="oe_highlight" invisible="qa_status != 'pending'"/>
                    <button name="action_fail_qa" string="Fail QA" type="object" class="btn-danger" invisible="qa_status != 'pending'"/>
                    <field name="qa_status" widget="statusbar" statusbar_visible="pending,passed,failed"/>
                </header>
            </xpath>
            <xpath expr="//group[@name='main_group']" position="after">
                <group string="Food QA &amp; Storage">
                    <field name="temperature_logged"/>
                    <field name="batch_notes"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
