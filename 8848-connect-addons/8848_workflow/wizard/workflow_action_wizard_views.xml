<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_workflow_action_wizard_form" model="ir.ui.view">
        <field name="name">8848.workflow.action.wizard.form</field>
        <field name="model">8848.workflow.action.wizard</field>
        <field name="arch" type="xml">
            <form string="Workflow Action">
                <sheet>
                    <group>
                        <field name="instance_id" invisible="1"/>
                        <field name="current_step_id" invisible="1"/>
                        <field name="transition_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="requires_comment" invisible="1"/>
                        <field name="requires_attachment" invisible="1"/>
                        
                        <field name="comment" required="requires_comment" invisible="not requires_comment"/>
                        <field name="attachment_name" invisible="1"/>
                        <field name="attachment" filename="attachment_name" required="requires_attachment" invisible="not requires_attachment"/>
                    </group>
                    <footer>
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
